# Copy this file to .env and fill in your keys

# Required: Anthropic Claude API key
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: HubSpot Private App access token
# Create one at https://developers.hubspot.com → Private Apps
# If omitted, the pipeline runs with mock IDs (all other stages still work)
HUBSPOT_ACCESS_TOKEN=pat-na1-...

# Optional: Resend API key for real email delivery (free tier: 3,000 emails/month)
# Sign up at https://resend.com — no credit card required
# If omitted, email sending is skipped gracefully (all other stages still work)
RESEND_API_KEY=re_...
